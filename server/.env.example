PORT=4000
CLIENT_ORIGIN=http://localhost:5173
# Required for end users to run analyses without needing their own token.
# GitHub's GraphQL API requires auth for every request, even public data,
# so this app needs at least one token to work out of the box. A classic
# PAT with no scopes checked (or a fine-grained token with read-only public
# repo access) is enough. Users can optionally override it with their own
# token from the UI's "Advanced" field.
GITHUB_TOKEN=
